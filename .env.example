# Copy this file to .env on IONOS. Do not commit real secrets.
NODE_ENV=production
SERVICE_NAME=fantasymmadness-swarm
PORT=8080
LOG_LEVEL=info

# MongoDB: use your Atlas URI at deploy time. Keep swarm data in its own DB.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=fantasymmadness_swarm

# Server-to-server security. Generate strong values with: npm run secret
SWARM_API_KEY=replace-with-a-long-random-api-key
SWARM_HMAC_KEY_ID=swarm-v1
SWARM_HMAC_SECRET=replace-with-a-long-random-hmac-secret
HMAC_MAX_SKEW_SECONDS=300

# CORS is mostly irrelevant for internal use, but keep it locked down.
CORS_ORIGINS=https://fantasymmadness.com,https://www.fantasymmadness.com
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240
API_BODY_LIMIT=1mb

# Worker controls.
WORKER_ID=ionos-worker-1
WORKER_CONCURRENCY=2
JOB_POLL_INTERVAL_MS=2500
JOB_LEASE_SECONDS=120
JOB_DEFAULT_MAX_ATTEMPTS=3
JOB_RETRY_BASE_DELAY_MS=30000

# Scheduler is disabled by default. Enable after manual jobs work.
SCHEDULER_ENABLED=false
SCHEDULED_INTERVAL_MS=3600000

# AI provider. If no key is set, deterministic placeholder generation is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_DISABLED=false
OPENAI_REQUEST_TIMEOUT_MS=45000

# Phase 2 callback target. Leave disabled in Phase 1 unless backend integration exists.
BACKEND_CALLBACK_ENABLED=false
BACKEND_BASE_URL=https://fantasymmadness-game-server-three.vercel.app
BACKEND_HMAC_KEY_ID=backend-v1
BACKEND_HMAC_SECRET=

# Phase 1 automation safety flags. Keep false until Phase 2/3 admin controls are live.
SWARM_DEFAULT_MODE=DRAFT_ONLY
SWARM_AUTO_PUBLISH_ENABLED=false
SWARM_AUTO_IMPORT_ENABLED=false
SWARM_SOCIAL_PUBLISH_ENABLED=false

# Optional social credentials. Phase 1 stores/generates drafts; live posting should stay disabled until approval flow is tested.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
