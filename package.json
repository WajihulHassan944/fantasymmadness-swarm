{
  "name": "fantasymmadness-centralized-swarm",
  "version": "1.3.0",
  "private": true,
  "description": "Centralized Phase 1 automation swarm for FantasyMMAdness combat, pro-wrestling, daily SEO, social, calendar, and growth workflows.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev:api": "tsx watch src/bootstrap/api.ts",
    "dev:worker": "tsx watch src/bootstrap/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/bootstrap/api.js",
    "start:worker": "node dist/bootstrap/worker.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "secret": "node scripts/generate-secret.mjs",
    "create:job": "node scripts/create-job.mjs"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "openai": "^4.80.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.6",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
